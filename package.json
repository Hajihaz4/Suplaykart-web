{
  "name": "suplaykart",
  "private": true,
  "description": "Suplaykart — hyperlocal q-commerce platform (Phase 1A: foundation + schema)",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @suplaykart/db generate",
    "db:migrate": "pnpm --filter @suplaykart/db migrate",
    "db:push": "pnpm --filter @suplaykart/db push",
    "db:studio": "pnpm --filter @suplaykart/db studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2"
  }
}
