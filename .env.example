# ──────────────────────────────────────────────────────────────
# Suplaykart — environment template (Phase 1A)
# Copy to `.env` (and/or apps/web/.env.local) and fill in real values.
# Never commit real secrets. .env / .env.local are gitignored.
# ──────────────────────────────────────────────────────────────

# Neon Postgres — use the POOLED connection string (…-pooler.…)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# Clerk — enable "Phone number" + SMS OTP in the Clerk Dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx"
# Required only for the Clerk → DB webhook (/api/webhooks/clerk)
CLERK_WEBHOOK_SIGNING_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional
# DB_POOL_MAX=10                  # node-postgres pool size (default 10)
# SKIP_ENV_VALIDATION=1           # skip env validation (e.g. CI builds without secrets)
